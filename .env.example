# ─── Environment ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── Store / Database ────────────────────────────────────────────────────
# MongoDB connection URI (use MONGO_URI or DBCon for backwards compat)
MONGO_URI=mongodb://localhost:27017
DBCon=mongodb://localhost:27017

# Database name within MongoDB
STORE_NAME=techcross

# ─── Domain ──────────────────────────────────────────────────────────────
# Primary deployment domain (e.g. techcross.ie, localhost)
DOMAIN=localhost

# ─── Secrets ──────────────────────────────────────────────────────────────
# POS system JWT secret (used by /api/inv/auth/*)
INV_JWT_SECRET=<your-pos-jwt-secret>

# SaaS platform JWT secret (used by /api/saas/auth/*, /api/saas/stores/*)
SAAS_JWT_SECRET=<your-saas-jwt-secret>

# Session secret for express sessions
SESSION_SECRET=<your-session-secret>

# Audit log encryption key
INV_AUDIT_KEY=<your-audit-encryption-key>

# Legacy admin token (used by some admin endpoints)
ADMIN_TOKEN=<your-admin-token>

# ─── Bootstrap Admin Account ─────────────────────────────────────────────
# Used by scripts/bootstrap-saas.js and scripts/bootstrap-users.js
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# ─── SMTP (Email Delivery) ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp_username
SMTP_PASS=smtp_password
SMTP_FROM=noreply@example.com

# ─── Google Analytics ────────────────────────────────────────────────────
# Leave empty to disable GA tracking
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ─── Print Agent ─────────────────────────────────────────────────────────
# URL of the local thermal printer agent
PRINT_AGENT_URL=http://localhost:9100

# ─── Company Info (Receipts, Invoices, Share Pages) ──────────────────────
COMPANY_NAME=TechCross Repair Centre
COMPANY_ADDRESS=Navan, Co. Meath, Ireland
COMPANY_PHONE=046 905 9854
COMPANY_EMAIL=info@example.com
VAT_NUMBER=IE3330982OH

# ─── Social Media ─────────────────────────────────────────────────────────
# Facebook page identifier (for social links)
FACEBOOK_PAGE=your-facebook-page
